# ==================== Database Configuration ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobpulse
DB_USERNAME=amine
DB_PASSWORD=amine
DB_POOL_SIZE=20
DB_POOL_MIN_IDLE=5

# ==================== Redis Configuration ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_POOL_SIZE=20

# ==================== Server Configuration ====================
SERVER_PORT=8080
PROFILE=dev

# ==================== JWT ====================
JWT_SECRET=your-jwt-secret-min-32-chars-long

# ==================== Google OAuth ====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4200/google/callback

# ==================== GitHub OAuth ====================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4200/github/callback

# ==================== Gmail OAuth (for email jobs) ====================
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:4200/gmail/callback
GMAIL_TOKEN_ENCRYPTION_KEY=

# ==================== Logging ====================
SHOW_SQL=false
